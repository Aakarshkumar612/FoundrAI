# FoundrAI — Environment Variable Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# In production, all secrets are injected via GCP Secret Manager into Cloud Run.

# ── Supabase ──────────────────────────────────────────────────────────────
# Your Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe for server-side use with RLS enabled)
SUPABASE_KEY=your-supabase-anon-key

# Supabase service role key (bypasses RLS — use ONLY in backend, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT secret for verifying Supabase-issued tokens in FastAPI middleware
# Found at: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Groq API ──────────────────────────────────────────────────────────────
# Groq free-tier API key (~10K tokens/min, ~500 tok/sec)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key

# ── GCP Cloud Storage ────────────────────────────────────────────────────
# GCS bucket name for raw uploads, model artifacts, and news cache
GCS_BUCKET_NAME=foundr-ai-storage

# GCP project ID
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for Cloud Run and Artifact Registry
GCP_REGION=us-central1

# Service account credentials as base64-encoded JSON (for non-Cloud Run envs)
# Generate: base64 -w 0 path/to/service-account.json
# In Cloud Run: use Workload Identity instead — leave this empty
GCP_SERVICE_ACCOUNT_JSON_B64=

# ── News Ingestion ────────────────────────────────────────────────────────
# NewsCatcher API key (OSS self-hosted or managed tier)
# https://www.newscatcherapi.com
NEWSCATCHER_API_KEY=your-newscatcher-api-key

# ── Apache Superset ───────────────────────────────────────────────────────
# Superset instance URL (local dev: http://localhost:8088)
SUPERSET_URL=http://localhost:8088

# Superset admin credentials for API calls (guest token generation)
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=your-superset-admin-password

# Secret used to sign Superset guest tokens for embedded dashboards
SUPERSET_GUEST_TOKEN_JWT_SECRET=your-superset-guest-token-secret

# ── Application Config ────────────────────────────────────────────────────
# Environment name: development | staging | production
ENVIRONMENT=development

# FastAPI allowed CORS origins (comma-separated, no trailing slash)
# Example: http://localhost:5173,https://app.foundrai.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Maximum file upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Port FastAPI runs on locally (Cloud Run always uses 8080)
PORT=8000

# ── Feature Flags ─────────────────────────────────────────────────────────
# Enable/disable background news ingestion scheduler
ENABLE_NEWS_SCHEDULER=true

# Enable AutoGluon as FLAML fallback (disable in memory-constrained envs)
ENABLE_AUTOGLUON_FALLBACK=false
