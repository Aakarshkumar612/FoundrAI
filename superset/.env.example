# Superset environment variables — copy to superset/.env

SUPERSET_SECRET_KEY=change-me-to-a-random-32char-string
SUPERSET_GUEST_TOKEN_JWT_SECRET=same-as-superset-guest-token-jwt-secret-in-root-env
POSTGRES_PASSWORD=superset_db_password

# Supabase PostgreSQL connection string (for dashboard data)
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URI=postgresql://postgres:your-pass@db.your-ref.supabase.co:5432/postgres

# Admin credentials for Superset UI
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASS=change-me
SUPERSET_ADMIN_EMAIL=admin@foundrai.com

# Frontend URL for CSP frame-ancestors
FRONTEND_URL=http://localhost:5173
